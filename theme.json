{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	],
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "720px",
			"wideSize": "1200px"
		},
		"color": {
			"palette": [
				{
					"slug": "base",
					"color": "#fafafa",
					"name": "Base"
				},
				{
					"slug": "contrast",
					"color": "#0f172a",
					"name": "Contrast"
				},
				{
					"slug": "primary",
					"color": "#4f46e5",
					"name": "Primary"
				},
				{
					"slug": "secondary",
					"color": "#64748b",
					"name": "Secondary"
				},
				{
					"slug": "surface",
					"color": "#f1f5f9",
					"name": "Surface"
				}
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"fontFamily": "\"Hanken Grotesk\", ui-sans-serif, system-ui, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\"",
					"name": "Hanken Grotesk",
					"slug": "sans"
				},
				{
					"fontFamily": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace",
					"name": "Monospace",
					"slug": "mono"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "0.875rem",
					"name": "Small"
				},
				{
					"slug": "base",
					"size": "1rem",
					"name": "Base"
				},
				{
					"slug": "medium",
					"size": "1.125rem",
					"name": "Medium"
				},
				{
					"slug": "large",
					"size": "1.5rem",
					"name": "Large"
				},
				{
					"slug": "x-large",
					"size": "1.875rem",
					"name": "Extra Large"
				},
				{
					"slug": "xx-large",
					"size": "2.25rem",
					"name": "Extra Extra Large"
				}
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"size": "0.5rem",
					"slug": "05",
					"name": "05"
				},
				{
					"size": "1rem",
					"slug": "10",
					"name": "10"
				},
				{
					"size": "2rem",
					"slug": "20",
					"name": "20"
				},
				{
					"size": "3rem",
					"slug": "30",
					"name": "30"
				},
				{
					"size": "4rem",
					"slug": "40",
					"name": "40"
				},
				{
					"size": "6rem",
					"slug": "50",
					"name": "50"
				}
			],
			"units": ["px", "em", "rem", "%", "vh", "vw"]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--sans)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.65"
		},
		"spacing": {
			"blockGap": "1.5rem"
		},
		"elements": {
			"heading": {
				"color": {
					"text": "var(--wp--preset--color--contrast)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--sans)",
					"fontWeight": "600",
					"lineHeight": "1.25"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"fontWeight": "700",
					"lineHeight": "1.15"
				},
				"spacing": {
					"margin": {
						"top": "0",
						"bottom": "var(--wp--preset--spacing--40)"
					}
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontWeight": "600",
					"lineHeight": "1.2"
				},
				"spacing": {
					"margin": {
						"top": "var(--wp--preset--spacing--20)",
						"bottom": "var(--wp--preset--spacing--10)"
					}
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"lineHeight": "1.25"
				},
				"spacing": {
					"margin": {
						"top": "var(--wp--preset--spacing--20)",
						"bottom": "var(--wp--preset--spacing--10)"
					}
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"lineHeight": "1.3"
				},
				"spacing": {
					"margin": {
						"top": "var(--wp--preset--spacing--10)",
						"bottom": "0.75rem"
					}
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--base)",
					"lineHeight": "1.35"
				},
				"spacing": {
					"margin": {
						"top": "var(--wp--preset--spacing--10)",
						"bottom": "0.5rem"
					}
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"textTransform": "uppercase",
					"letterSpacing": "0.06em",
					"lineHeight": "1.4"
				},
				"spacing": {
					"margin": {
						"top": "var(--wp--preset--spacing--10)",
						"bottom": "0.5rem"
					}
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				"typography": {
					"textDecoration": "underline"
				},
				":hover": {
					"typography": {
						"textDecoration": "none"
					}
				},
				":focus": {
					"typography": {
						"textDecoration": "underline"
					}
				}
			},
			"cite": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontStyle": "italic"
				},
				"color": {
					"text": "var(--wp--preset--color--secondary)"
				}
			},
			"caption": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"lineHeight": "1.5"
				},
				"color": {
					"text": "var(--wp--preset--color--secondary)"
				},
				"spacing": {
					"margin": {
						"top": "0.5rem",
						"bottom": "0"
					}
				}
			},
			"button": {
				"color": {
					"text": "var(--wp--preset--color--base)",
					"background": "var(--wp--preset--color--primary)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "600",
					"textDecoration": "none"
				},
				"border": {
					"radius": "0.375rem",
					"width": "0",
					"style": "none"
				},
				"spacing": {
					"padding": {
						"top": "0.65em",
						"right": "1.25em",
						"bottom": "0.65em",
						"left": "1.25em"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--contrast)",
						"text": "var(--wp--preset--color--base)"
					}
				}
			}
		},
		"blocks": {
			"core/paragraph": {
				"typography": {
					"lineHeight": "1.65"
				},
				"spacing": {
					"margin": {
						"top": "0",
						"bottom": "0"
					}
				}
			},
			"core/heading": {
				"typography": {
					"fontWeight": "600",
					"lineHeight": "1.25"
				},
				"spacing": {
					"margin": {
						"top": "0",
						"bottom": "0"
					}
				}
			},
			"core/list": {
				"spacing": {
					"padding": {
						"left": "1.25rem"
					},
					"margin": {
						"top": "0",
						"bottom": "0"
					}
				},
				"typography": {
					"lineHeight": "1.65"
				}
			},
			"core/quote": {
				"border": {
					"top": {
						"width": "0"
					},
					"right": {
						"width": "0"
					},
					"bottom": {
						"width": "0"
					},
					"left": {
						"color": "var(--wp--preset--color--primary)",
						"style": "solid",
						"width": "4px"
					}
				},
				"spacing": {
					"padding": {
						"left": "var(--wp--preset--spacing--30)",
						"right": "var(--wp--preset--spacing--30)"
					},
					"margin": {
						"top": "0",
						"bottom": "0"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontStyle": "normal",
					"lineHeight": "1.6"
				},
				"elements": {
					"cite": {
						"typography": {
							"fontSize": "var(--wp--preset--font-size--small)",
							"fontStyle": "normal",
							"fontWeight": "600"
						},
						"color": {
							"text": "var(--wp--preset--color--secondary)"
						}
					}
				}
			},
			"core/pullquote": {
				"border": {
					"top": {
						"color": "var(--wp--preset--color--secondary)",
						"style": "solid",
						"width": "1px"
					},
					"right": {
						"width": "0"
					},
					"bottom": {
						"color": "var(--wp--preset--color--secondary)",
						"style": "solid",
						"width": "1px"
					},
					"left": {
						"width": "0"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"lineHeight": "1.35",
					"fontStyle": "normal"
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--30)",
						"bottom": "var(--wp--preset--spacing--30)"
					},
					"margin": {
						"top": "var(--wp--preset--spacing--40)",
						"bottom": "var(--wp--preset--spacing--40)"
					}
				},
				"elements": {
					"cite": {
						"typography": {
							"fontSize": "var(--wp--preset--font-size--small)",
							"fontStyle": "normal",
							"textTransform": "none"
						}
					}
				}
			},
			"core/table": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"lineHeight": "1.5"
				},
				"border": {
					"width": "1px",
					"style": "solid",
					"color": "var(--wp--preset--color--secondary)"
				},
				"elements": {
					"caption": {
						"typography": {
							"fontSize": "var(--wp--preset--font-size--small)"
						},
						"color": {
							"text": "var(--wp--preset--color--secondary)"
						},
						"spacing": {
							"margin": {
								"top": "0.5rem",
								"bottom": "0"
							}
						}
					}
				}
			},
			"core/code": {
				"color": {
					"background": "var(--wp--preset--color--surface)",
					"text": "var(--wp--preset--color--contrast)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)",
					"fontSize": "var(--wp--preset--font-size--small)",
					"lineHeight": "1.55"
				},
				"spacing": {
					"padding": {
						"top": "1rem",
						"right": "1.25rem",
						"bottom": "1rem",
						"left": "1.25rem"
					},
					"margin": {
						"top": "0",
						"bottom": "0"
					}
				},
				"border": {
					"radius": "0.375rem",
					"width": "1px",
					"style": "solid",
					"color": "var(--wp--preset--color--secondary)"
				}
			},
			"core/preformatted": {
				"color": {
					"background": "var(--wp--preset--color--surface)",
					"text": "var(--wp--preset--color--contrast)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)",
					"fontSize": "var(--wp--preset--font-size--small)",
					"lineHeight": "1.55"
				},
				"spacing": {
					"padding": {
						"top": "1rem",
						"right": "1.25rem",
						"bottom": "1rem",
						"left": "1.25rem"
					},
					"margin": {
						"top": "0",
						"bottom": "0"
					}
				},
				"border": {
					"radius": "0.375rem",
					"width": "1px",
					"style": "solid",
					"color": "var(--wp--preset--color--secondary)"
				}
			},
			"core/image": {
				"spacing": {
					"margin": {
						"top": "0",
						"bottom": "0"
					}
				}
			},
			"core/gallery": {
				"spacing": {
					"margin": {
						"top": "0",
						"bottom": "0"
					},
					"blockGap": "var(--wp--preset--spacing--10)"
				}
			},
			"core/buttons": {
				"spacing": {
					"blockGap": "var(--wp--preset--spacing--10)",
					"margin": {
						"top": "0",
						"bottom": "0"
					}
				}
			},
			"core/separator": {
				"color": {
					"background": "var(--wp--preset--color--secondary)"
				},
				"spacing": {
					"margin": {
						"top": "var(--wp--preset--spacing--40)",
						"bottom": "var(--wp--preset--spacing--40)"
					}
				}
			},
			"core/embed": {
				"spacing": {
					"margin": {
						"top": "0",
						"bottom": "0"
					}
				}
			}
		}
	}
}