{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "nextora/hero-section",
  "title": "Hero Section",
  "category": "theme",
  "description": "Two-column hero: copy and supporting visuals. Layout uses CSS clamp() for small screens; use the sidebar to adjust column ratio and order.",
  "keywords": [
    "hero",
    "banner",
    "nextora"
  ],
  "textdomain": "nextora",
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ],
    "color": {
      "background": true,
      "text": true,
      "link": true
    },
    "spacing": {
      "padding": true,
      "margin": true,
      "blockGap": true
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true
    },
    "dimensions": {
      "minHeight": true
    }
  },
  "attributes": {
    "columnSplit": {
      "type": "string",
      "default": "50-50"
    },
    "creativePosition": {
      "type": "string",
      "default": "right"
    },
    "stackOrder": {
      "type": "string",
      "default": "content-first"
    },
    "verticalAlign": {
      "type": "string",
      "default": "center"
    },
    "heading": {
      "type": "string",
      "default": ""
    },
    "content": {
      "type": "string",
      "default": ""
    }
  },
  "editorScript": "file:./index.js",
  "render": "file:./render.php"
}
