{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "nextora/call-to-action",
  "title": "Call to action",
  "category": "theme",
  "description": "Prominent CTA banner: two flexible columns (copy and visuals) like the hero, plus optional full-bleed image, video, or color-mix background and parallax.",
  "keywords": ["call-to-action", "cta", "banner", "nextora"],
  "textdomain": "nextora",
  "style": "file:./style.css",
  "editorStyle": "file:./editor.css",
  "supports": {
    "html": false,
    "align": ["wide", "full"],
    "dimensions": {
      "minHeight": true
    }
  },
  "attributes": {
    "columnSplit": {
      "type": "string",
      "default": "50-50"
    },
    "creativePosition": {
      "type": "string",
      "default": "right"
    },
    "stackOrder": {
      "type": "string",
      "default": "content-first"
    },
    "verticalAlign": {
      "type": "string",
      "default": "center"
    },
    "stickyColumn": {
      "type": "string",
      "default": "none"
    },
    "heading": {
      "type": "string",
      "default": ""
    },
    "content": {
      "type": "string",
      "default": ""
    },
    "backgroundMode": {
      "type": "string",
      "default": "solid"
    },
    "backgroundImageId": {
      "type": "number",
      "default": 0
    },
    "backgroundVideoId": {
      "type": "number",
      "default": 0
    },
    "colorMixA": {
      "type": "string",
      "default": "#1d4ed8"
    },
    "colorMixB": {
      "type": "string",
      "default": "#0f172a"
    },
    "colorMixRatio": {
      "type": "number",
      "default": 50
    },
    "overlayOpacity": {
      "type": "number",
      "default": 40
    },
    "parallaxEnabled": {
      "type": "boolean",
      "default": false
    },
    "parallaxStrength": {
      "type": "number",
      "default": 30
    },
    "borderRadius": {
      "type": "string",
      "default": "none"
    }
  },
  "editorScript": "file:./index.js",
  "viewScript": "file:./view.js",
  "render": "file:./render.php"
}
