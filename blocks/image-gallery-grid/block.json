{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "nextora/image-gallery-grid",
  "title": "Image gallery (grid)",
  "category": "media",
  "description": "A responsive image grid. Choose a layout preset (classic or creative bento, spotlight, editorial) and 3–6 images for the styled layouts.",
  "keywords": [
    "image",
    "gallery",
    "grid",
    "bento",
    "spotlight",
    "editorial",
    "photos",
    "nextora"
  ],
  "textdomain": "nextora",
  "style": "file:./style.css",
  "editorStyle": "file:./editor.css",
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ],
    "color": {
      "background": true,
      "text": true,
      "link": true
    },
    "spacing": {
      "padding": true,
      "margin": true,
      "blockGap": true
    }
  },
  "attributes": {
    "gridLayout": {
      "type": "string",
      "default": "classic"
    },
    "imageIds": {
      "type": "array",
      "default": []
    },
    "columnsMobile": {
      "type": "number",
      "default": 2
    },
    "columnsTablet": {
      "type": "number",
      "default": 3
    },
    "columnsDesktop": {
      "type": "number",
      "default": 4
    },
    "gap": {
      "type": "number",
      "default": 12
    },
    "imageFit": {
      "type": "string",
      "default": "cover"
    },
    "imageAreaBackground": {
      "type": "string",
      "default": ""
    },
    "showCaptions": {
      "type": "boolean",
      "default": true
    }
  },
  "editorScript": "file:./index.js",
  "viewScript": "file:./view.js",
  "render": "file:./render.php"
}
