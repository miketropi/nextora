{
	"name": "nextora-theme",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "npm run build:css && npm run build:ts && npm run build:blocks",
		"build:css": "postcss ./resources/css/app.css -o ./assets/css/app.css --verbose",
		"build:ts": "esbuild ./resources/ts/main.ts --bundle --outfile=./assets/js/main.js --target=es2020 --platform=browser --minify",
		"build:blocks": "node ./scripts/build-blocks.mjs",
		"watch": "concurrently --group -n CSS,TS,Blocks -c cyan,yellow,magenta \"npm run -s watch:css\" \"npm run -s watch:ts\" \"npm run -s watch:blocks\"",
		"watch:css": "node ./scripts/watch-css.mjs",
		"watch:ts": "esbuild ./resources/ts/main.ts --bundle --outfile=./assets/js/main.js --target=es2020 --platform=browser --watch --sourcemap",
		"watch:blocks": "node ./scripts/build-blocks.mjs --watch",
		"typecheck": "tsc --noEmit",
		"lint:php": "composer phpstan",
		"theme:clone": "node ./scripts/clone-theme.mjs",
		"gen": "node ./scripts/gen-block.mjs"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.2.2",
		"@types/wordpress__block-editor": "^15.0.5",
		"@types/wordpress__blocks": "^15.10.2",
		"@wordpress/block-editor": "^15.16.0",
		"@wordpress/blocks": "^15.16.0",
		"@wordpress/components": "^32.5.0",
		"@wordpress/element": "^6.43.0",
		"@wordpress/i18n": "^6.16.0",
		"@wordpress/server-side-render": "^6.19.0",
		"chokidar-cli": "^3.0.0",
		"concurrently": "^9.2.1",
		"esbuild": "^0.25.0",
		"glob": "^13.0.6",
		"postcss": "^8.5.3",
		"postcss-cli": "^11.0.1",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.8.2"
	},
	"dependencies": {
		"@tiptap/core": "^3.22.2",
		"@tiptap/extension-link": "^3.22.2",
		"@tiptap/extension-placeholder": "^3.22.2",
		"@tiptap/pm": "^3.22.2",
		"@tiptap/starter-kit": "^3.22.2",
		"gsap": "^3.15.0",
		"lucide": "^1.7.0",
		"swiper": "^11.2.10"
	}
}
