{
	"name": "nextora-theme",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "npm run build:css && npm run build:ts",
		"build:css": "postcss ./resources/css/app.css -o ./assets/css/app.css --verbose",
		"build:ts": "esbuild ./resources/ts/main.ts --bundle --outfile=./assets/js/main.js --target=es2020 --platform=browser",
		"watch": "npm run watch:css & npm run watch:ts",
		"watch:css": "postcss ./resources/css/app.css -o ./assets/css/app.css --verbose --watch",
		"watch:ts": "esbuild ./resources/ts/main.ts --bundle --outfile=./assets/js/main.js --target=es2020 --platform=browser --watch",
		"typecheck": "tsc --noEmit",
		"lint:php": "composer phpstan",
		"theme:clone": "node ./scripts/clone-theme.mjs"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.2.2",
		"esbuild": "^0.25.0",
		"postcss": "^8.5.3",
		"postcss-cli": "^11.0.1",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.8.2"
	}
}
